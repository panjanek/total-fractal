<Window x:Class="TotalFractal.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Config" Width="540" SizeToContent="Height"
        WindowStartupLocation="Manual">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
        <StackPanel>
            <!-- Top button row. More buttons will be added here later. -->
            <StackPanel Orientation="Horizontal" Margin="2,2,2,6">
                <Button Content="Toggle display" Command="{Binding ToggleDisplayCommand}"
                        Padding="8,2" Margin="2,0" />
            </StackPanel>

            <!-- Grid structure: dropdowns that change the seed buffer / splat size. -->
            <GroupBox Header="Grid" Margin="2,2,2,6" Padding="4">
                <StackPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="{Binding SplatSize.Label}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding SplatSize.Options}"
                                  SelectedItem="{Binding SplatSize.Value, Mode=TwoWay}" />
                    </DockPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="{Binding AxisCount.Label}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding AxisCount.Options}"
                                  SelectedItem="{Binding AxisCount.Value, Mode=TwoWay}" />
                    </DockPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="{Binding PointsPerAxis.Label}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding PointsPerAxis.Options}"
                                  SelectedItem="{Binding PointsPerAxis.Value, Mode=TwoWay}" />
                    </DockPanel>
                    <DockPanel Margin="2,6,2,3">
                        <TextBlock Width="110" Text="{Binding Iterations.Label}" VerticalAlignment="Center" />
                        <TextBlock DockPanel.Dock="Right" Width="40" TextAlignment="Right"
                                   Text="{Binding Iterations.Value, StringFormat=F0}" VerticalAlignment="Center" />
                        <Slider Minimum="{Binding Iterations.Min}" Maximum="{Binding Iterations.Max}"
                                Value="{Binding Iterations.Value, Mode=TwoWay}"
                                IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                    </DockPanel>
                    <CheckBox Content="{Binding PlotAll.Label}" IsChecked="{Binding PlotAll.Value, Mode=TwoWay}"
                              Margin="2,6,2,3" VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox>

            <!-- Escape-time fractal panels (escape + coefficients). -->
            <GroupBox Header="Fractal" Margin="2,2,2,6" Padding="4">
                <StackPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="{Binding MaxIterations.Label}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding MaxIterations.Options}"
                                  SelectedItem="{Binding MaxIterations.Value, Mode=TwoWay}" />
                    </DockPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="Coeff pair" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding CoeffPairs}" DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedCoeffPair, Mode=TwoWay}" />
                    </DockPanel>
                    <DockPanel Margin="2,3">
                        <TextBlock Width="110" Text="Color map" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding ColorMaps}" DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedColorMap, Mode=TwoWay}" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- The 12 quadratic-map coefficients. One labeled slider per SliderParam. -->
            <GroupBox Header="Coefficients" Margin="2" Padding="4">
                <ItemsControl ItemsSource="{Binding Coefficients}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Margin="0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="Background" Value="#332D7DD2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" />
                                    <Slider Grid.Column="1" VerticalAlignment="Center"
                                            Minimum="{Binding Min}" Maximum="{Binding Max}"
                                            SmallChange="0.001"
                                            Value="{Binding Value, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat=F3}"
                                               TextAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</Window>
